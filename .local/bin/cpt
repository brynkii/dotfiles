#!/usr/bin/env bash
# move-to-last-pane.sh
# Move files from current tmux pane to last, with undo support and previews.

LOG_FILE="${XDG_CACHE_HOME:-$HOME/.cache}/mv-to-last-pane.log"
mkdir -p "$(dirname "$LOG_FILE")"

_bold()   { printf "\033[1m%s\033[0m\n" "$*"; }
_green()  { printf "\033[0;32m%s\033[0m\n" "$*"; }
_red()    { printf "\033[0;31m%s\033[0m\n" "$*"; }

# Get pane path safely
_get_pane_info() {
    local pane_id="$1"
    tmux display-message -p -t "$pane_id" -F "#{pane_current_path}" 2>/dev/null || {
        _red "Error: Cannot access pane $pane_id"
        return 1
    }
}

# Core copy function (always recursive for dirs)
_copy() {
    local src dst files=("$@")

    src=$(_get_pane_info "$(tmux display-message -p -F '#{pane_id}')") || return 1
    dst=$(_get_pane_info "$(tmux display-message -p -t '{last}' -F '#{pane_id}')") || return 1

    cd "$src" || return 1
    shopt -s nullglob dotglob
    [[ ${#files[@]} -eq 0 ]] && { _red "No matches."; return 1; }

    local ts=$(date +%s)
    printf "=== %s ===\n" "$ts" >>"$LOG_FILE"

    for f in "${files[@]}"; do
        [[ -e "$f" ]] || { _red "Not found: $f"; continue; }
        echo "$dst|$src/$f|copy" >>"$LOG_FILE"
        cp -r -- "$f" "$dst/" && _green "Copied $f → $dst/"
    done
}

# FZF-based multi-select
_fzf_copy() {
    local src dst
    src=$(_get_pane_info "$(tmux display-message -p -F '#{pane_id}')") || return 1
    dst=$(_get_pane_info "$(tmux display-message -p -t '{last}' -F '#{pane_id}')") || return 1
    cd "$src" || return 1

    command -v fzf >/dev/null || { _red "Error: fzf required"; return 1; }

    mapfile -d '' selected < <(
        find . -maxdepth 1 ! -name "." -printf '%P\0' |
        fzf --multi \
            --prompt="Select files: " \
            --preview='
                item={}
                if [ -d "$item" ]; then
                    echo "Directory: $item"
                    ls -la "$item" 2>/dev/null | head -10
                elif [ -f "$item" ]; then
                    echo "File: $item"
                    echo "Size: $(du -h "$item" 2>/dev/null | cut -f1)"
                    head -5 "$item" 2>/dev/null
                else
                    echo "Special: $item"
                fi
            ' --preview-window=right:50% --print0
    )

    [[ ${#selected[@]} -eq 0 ]] && { echo "No selection."; return; }

    local ts=$(date +%s)
    printf "=== %s ===\n" "$ts" >>"$LOG_FILE"

    for f in "${selected[@]}"; do
        echo "$dst|$src/$f|copy" >>"$LOG_FILE"
        cp -r -- "$f" "$dst/" && _green "Copied $f → $dst/"
    done
}

case "$1" in
    -f|--fzf-copy) shift; _fzf_copy "$@" ;;
    *) _copy "$@" ;;
esac
